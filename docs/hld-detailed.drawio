          <mxGeometry x="160" y="270" width="1050" height="230" as="geometry" />
        </mxCell>
        <mxCell id="api-title" value="⚡ Express API Server (Node.js + TypeScript) — Port 3000" style="text;html=1;fontSize=14;fontStyle=1;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="350" y="275" width="500" height="25" as="geometry" />
