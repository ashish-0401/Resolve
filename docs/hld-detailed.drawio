        <mxCell id="a1" value="HTTPS&#xa;JWT in httpOnly cookie&#xa;credentials: true (CORS)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#333;fontSize=9;fontStyle=2;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="pwa" target="api">
          <mxGeometry relative="1" as="geometry" />
